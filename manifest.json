{
  "manifest_version": 3,
  "name": "ColorKit",
  "version": "1.0.0",
  "description": "设计师配色工具箱 — 取色/调色板/色彩搭配生成器",
  "homepage_url": "https://479464887-rgb.github.io/colorkit/",
  "author": {"email": "tulv202900@163.com"},
  "permissions": ["storage", "commands"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ColorKit"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+C", "mac": "Command+Shift+C" },
      "description": "打开 ColorKit"
    }
  }
}
